{
  "expo": {
    "name": "Arena",
    "slug": "al-maydan",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "arena",
    "userInterfaceStyle": "automatic",
    "description": "Arena — The Challenge Arena. Compete with friends in trivia and multiplayer games.",
    "primaryColor": "#f5c518",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "assetBundlePatterns": [
      "assets/sounds/*",
      "assets/images/*",
      "assets/*.png",
      "assets/*.jpg"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.almaydan.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "CFBundleLocalizations": [
          "en",
          "ar"
        ],
        "CFBundleDevelopmentRegion": "en"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e1040"
      },
      "package": "com.almaydan.app",
      "versionCode": 3,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "googleServicesFile": "./google-services.json",
      "backgroundColor": "#0a0a1a",
      "splash": {
        "backgroundColor": "#0a0a1a",
        "resizeMode": "contain"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-apple-authentication",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Arena to access your microphone for voice features."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Arena to access your photos to set a profile picture.",
          "cameraPermission": "Allow Arena to access your camera."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "af3f8e44-f1a9-4fe9-ab65-d922761b4079"
      }
    },
    "owner": "hah01",
    "androidStatusBar": {
      "backgroundColor": "#0a0a1a",
      "barStyle": "light-content",
      "translucent": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#0a0a1a",
      "barStyle": "light-content"
    }
  }
}
